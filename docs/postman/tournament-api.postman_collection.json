{
  "info": {
    "name": "Tournament API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "authToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "gameId", "value": "" },
    { "key": "tournamentId", "value": "" },
    { "key": "fullTournamentId", "value": "" },
    { "key": "playerId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"player1\",\n  \"email\": \"player1@example.com\",\n  \"password\": \"Password1\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('authToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player1@example.com\",\n  \"password\": \"Password1\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('authToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register — duplicate email (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"player2\",\n  \"email\": \"player1@example.com\",\n  \"password\": \"Password1\"\n}"
            }
          }
        },
        {
          "name": "Login — wrong password (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player1@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Games",
      "item": [
        {
          "name": "GET List Games — public",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/games",
            "description": "Liste publique de tous les jeux. 200 → { success: true, data: [] }"
          }
        },
        {
          "name": "POST Create Game — admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/games",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Street Fighter 6\",\n  \"publisher\": \"Capcom\",\n  \"releaseDate\": \"2023-06-02\",\n  \"genre\": \"Fighting\"\n}"
            },
            "description": "Création avec token admin. 201 → { success: true, data: { id, name, ... } }"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('gameId', json.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Create Game — non authentifié (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/games",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Game\",\n  \"publisher\": \"Test\",\n  \"releaseDate\": \"2023-01-01\",\n  \"genre\": \"Action\"\n}"
            },
            "description": "Sans token. 401 attendu."
          }
        },
        {
          "name": "POST Create Game — user non admin (403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/games",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Game\",\n  \"publisher\": \"Test\",\n  \"releaseDate\": \"2023-01-01\",\n  \"genre\": \"Action\"\n}"
            },
            "description": "Token user normal (isAdmin false). 403 attendu."
          }
        },
        {
          "name": "POST Create Game — nom dupliqué (409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/games",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Street Fighter 6\",\n  \"publisher\": \"Capcom\",\n  \"releaseDate\": \"2023-06-02\",\n  \"genre\": \"Fighting\"\n}"
            },
            "description": "Même nom qu'une création précédente. 409 attendu."
          }
        },
        {
          "name": "POST Create Game — body invalide (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/games",
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "description": "Body vide. 400 avec tableau de messages attendu."
          }
        }
      ]
    },
    {
      "name": "Tournaments",
      "item": [
        {
          "name": "GET List Tournaments — public",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/tournaments",
            "description": "Liste publique. 200 → { success: true, data: [] }"
          }
        },
        {
          "name": "GET List Tournaments — filtre par status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tournaments?status=pending",
              "host": ["{{baseUrl}}"],
              "path": ["tournaments"],
              "query": [{ "key": "status", "value": "pending" }]
            },
            "description": "Filtre par status. Valeurs : pending, in_progress, completed."
          }
        },
        {
          "name": "POST Create Tournament",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/tournaments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Summer Cup 2026\",\n  \"gameId\": \"{{gameId}}\",\n  \"maxPlayers\": 4,\n  \"startDate\": \"2026-07-01T10:00:00.000Z\"\n}"
            },
            "description": "Créer un tournoi. 201 → { success: true, data: { id, ... } }"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('tournamentId', json.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Tournament by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/tournaments/{{tournamentId}}",
            "description": "Détails d'un tournoi. 200 → tournament complet."
          }
        },
        {
          "name": "GET Tournament by ID — inexistant (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/tournaments/00000000-0000-0000-0000-000000000000",
            "description": "UUID valide mais inexistant. 404 attendu."
          }
        },
        {
          "name": "GET Tournament by ID — UUID invalide (400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/tournaments/not-a-uuid",
            "description": "UUID invalide. 400 attendu (ParseUUIDPipe)."
          }
        },
        {
          "name": "PUT Update Tournament",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/tournaments/{{tournamentId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Summer Cup 2026 — Updated\"\n}"
            },
            "description": "Mise à jour partielle. 200 → tournament mis à jour."
          }
        },
        {
          "name": "DELETE Tournament",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/tournaments/{{tournamentId}}",
            "description": "Suppression. 200 → { success: true, data: { deleted: true } }"
          }
        },
        {
          "name": "POST Join Tournament",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/tournaments/{{tournamentId}}/join",
            "description": "Inscription au tournoi. 200 → { success: true, data: { joined: true } }"
          }
        },
        {
          "name": "POST Join Tournament — double join (409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/tournaments/{{tournamentId}}/join",
            "description": "Même joueur, même tournoi. 409 attendu."
          }
        },
        {
          "name": "POST Join Tournament — non authentifié (401)",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/tournaments/{{tournamentId}}/join",
            "description": "Sans token. 401 attendu."
          }
        },
        {
          "name": "POST Create Tournament maxPlayers 2 — test plein",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/tournaments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mini Cup\",\n  \"gameId\": \"{{gameId}}\",\n  \"maxPlayers\": 2,\n  \"startDate\": \"2026-07-01T10:00:00.000Z\"\n}"
            },
            "description": "Tournoi à 2 places max pour tester le cas plein."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('fullTournamentId', json.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Join Tournament — tournoi plein (422)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/tournaments/{{fullTournamentId}}/join",
            "description": "Après 2 inscriptions. 422 BusinessRuleViolation attendu."
          }
        }
      ]
    },
    {
      "name": "Players",
      "item": [
        {
          "name": "GET List Players — public",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/players",
            "description": "Liste publique de tous les joueurs. VÉRIFIER : aucun objet ne contient le champ 'password'."
          }
        },
        {
          "name": "GET Player by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/players/{{playerId}}",
            "description": "Profil d'un joueur. VÉRIFIER : 'password' absent de la réponse."
          }
        },
        {
          "name": "GET Player by ID — inexistant (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/players/00000000-0000-0000-0000-000000000000",
            "description": "UUID valide mais inexistant. 404 attendu."
          }
        },
        {
          "name": "GET Player by ID — UUID invalide (400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/players/not-a-uuid",
            "description": "UUID invalide. 400 attendu (ParseUUIDPipe)."
          }
        },
        {
          "name": "GET Player Tournaments",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/players/{{playerId}}/tournaments",
            "description": "Liste des tournois du joueur. 200 → { success: true, data: [...tournaments] }"
          }
        },
        {
          "name": "GET Player Tournaments — joueur inexistant (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/players/00000000-0000-0000-0000-000000000000/tournaments",
            "description": "Joueur inexistant. 404 attendu."
          }
        },
        {
          "name": "GET Player Rankings — placeholder",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/players/rankings",
            "description": "Placeholder Bonus B3. 200 → { success: true, data: [] }"
          }
        },
        {
          "name": "GET Player Stats — placeholder",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/players/{{playerId}}/stats",
            "description": "Placeholder Bonus B3. 200 → { success: true, data: {} }"
          }
        }
      ]
    }
  ]
}
